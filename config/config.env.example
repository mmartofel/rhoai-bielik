# =============================================================================
# Konfiguracja deploymentu Bielik-11B na RHOAI 3.4
# =============================================================================
# WAŻNE: Uzupełnij HF_TOKEN swoim tokenem HuggingFace przed uruchomieniem deploy.sh
# Ten plik jest wersjonowany jako szablon — upewnij się że nie committujesz tokenu!

# --- Namespace i nazwa modelu ---
NAMESPACE="bielik-demo"
MODEL_NAME="bielik-11b"

# --- HuggingFace ---
HF_MODEL_URI="hf://speakleash/Bielik-11B-v2.3-Instruct-GPTQ"
HF_TOKEN=""   # Use your own HF tokenem here.

# --- Konfiguracja równoległości ---
# Pipeline parallelism: liczba nodów (stages pipeline) — model 11B podzielony na 3 GPU
PIPELINE_PARALLEL_SIZE="3"
# Tensor parallelism: liczba GPU per nod (g4dn.2xlarge ma 1× T4)
TENSOR_PARALLEL_SIZE="1"

# --- Parametry modelu ---
MAX_MODEL_LEN="4096"
GPU_MEMORY_UTILIZATION="0.85"
DTYPE="float16"

# --- Zasoby per pod ---
CPU_REQUEST="4"
CPU_LIMIT="8"
MEMORY_REQUEST="16Gi"
MEMORY_LIMIT="24Gi"
GPU_COUNT="1"

# --- Timeouty i polling ---
DEPLOY_TIMEOUT_SECONDS="1200"   # 20 minut
POLL_INTERVAL_SECONDS="30"
