# =============================================================================
# Konfiguracja deploymentu Bielik-11B na RHOAI 3.4  (PRZYKŁAD — bez tokenu)
# =============================================================================
# Skopiuj do config.env i uzupełnij HF_TOKEN przed uruchomieniem deploy.sh

# --- Namespace i nazwa modelu ---
NAMESPACE="bielik-demo"
MODEL_NAME="bielik-11b"

# --- HuggingFace (tylko do jednorazowego pobrania modelu) ---
HF_MODEL_ID="speakleash/Bielik-11B-v2.3-Instruct-GPTQ"
HF_TOKEN=""   # Wstaw swój token HuggingFace (https://huggingface.co/settings/tokens)

# --- MinIO — lokalne repozytorium modeli (rhoai-model-registries namespace) ---
MINIO_NAMESPACE="rhoai-model-registries"
MINIO_ENDPOINT="http://minio.rhoai-model-registries.svc.cluster.local:9000"
MINIO_BUCKET="bielik-models"
MINIO_ACCESS_KEY="minio"
MINIO_SECRET_KEY="minio123"
MODEL_S3_PATH="Bielik-11B-v2.3-Instruct-GPTQ"

# --- Konfiguracja równoległości (multi-node pipeline) ---
PIPELINE_PARALLEL_SIZE="3"
TENSOR_PARALLEL_SIZE="1"

# --- Parametry modelu ---
MAX_MODEL_LEN="4096"
GPU_MEMORY_UTILIZATION="0.85"
DTYPE="float16"

# --- Zasoby per pod ---
CPU_REQUEST="1"
CPU_LIMIT="8"
MEMORY_REQUEST="12Gi"
MEMORY_LIMIT="24Gi"
GPU_COUNT="1"

# --- Timeouty i polling ---
DEPLOY_TIMEOUT_SECONDS="1200"
POLL_INTERVAL_SECONDS="30"
TRANSFER_TIMEOUT_SECONDS="3600"
